{
  "name": "@mutual-processadora-de-pagamentos/lib-ui",
  "version": "0.12.5",
  "description": "Camada compartilhada de frontend da Mutual Pay — Design System (tokens CSS + primitivos React) e contratos de domínio (TS puro, ex.: cripto/OTC).",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts/crypto": {
      "types": "./dist/contracts/crypto.d.ts",
      "import": "./dist/contracts/crypto.js"
    },
    "./tokens.css": "./src/tokens/tokens.css"
  },
  "files": [
    "dist",
    "src/tokens"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mutual-Processadora-de-Pagamentos/lib-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
